modules = ["nodejs-24"]
run = "pnpm run dev"
entrypoint = "artifacts/mobile/app/_layout.tsx"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mobile"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Qlue App"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
